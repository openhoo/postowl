{
  "name": "postowl",
  "version": "0.5.3",
  "private": true,
  "description": "A fast, native REST workspace",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "tsc --noEmit",
    "test:e2e:build": "pnpm build && cargo build --manifest-path src-tauri/Cargo.toml --features e2e,tauri/custom-protocol",
    "test:e2e": "pnpm test:e2e:build && pnpm test:e2e:run",
    "test:e2e:run": "wdio run ./wdio.conf.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-service": "^1.2.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-plugin-solid": "^2.11.10"
  },
  "packageManager": "pnpm@11.3.0",
  "license": "MIT"
}
