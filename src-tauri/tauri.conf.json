{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PostOwl",
  "version": "0.6.0",
  "identifier": "xyz.openhoo.postowl",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "PostOwl",
        "width": 1440,
        "height": 900,
        "minWidth": 640,
        "minHeight": 680,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A fast, native REST workspace",
    "longDescription": "Build, organize, automate, and inspect HTTP requests without a heavyweight runtime."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1ODNDQUY4QzJDOTA5MUEKUldRYUNjbkMrTXFENWYzck93dytjSUZoNWpXVUlLQUhTcjdhWldSTXJXM1d4WnA3U2wrNnVYR2gK",
      "endpoints": [
        "https://github.com/openhoo/postowl/releases/latest/download/latest.json"
      ]
    }
  }
}
